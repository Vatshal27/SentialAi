{
  "name": "sentinelai",
  "displayName": "secure-dev-tool",
  "description": "AI-powered developer security tool",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Other"],

  "activationEvents": [
    "onCommand:secure-dev-tool.scan"
  ],

  "main": "./out/extension.js",

  "contributes": {
    "commands": [
      {
        "command": "secure-dev-tool.scan",
        "title": "Scan Code for Vulnerabilities"
      }
    ]
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },

  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  },

  "dependencies": {
    "axios": "^1.13.6"
  }
}